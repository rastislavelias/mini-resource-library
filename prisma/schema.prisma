generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResourceStatus {
  TO_READ
  READING
  FINISHED
}

enum CategoryColor {
  BLUE
  GREEN
  ORANGE
  PINK
  PURPLE
  RED
  SLATE
  YELLOW
}

model Category {
  id        String        @id @default(cuid())
  userId    String
  name      String
  color     CategoryColor @default(SLATE)
  resources Resource[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Resource {
  id         String         @id @default(cuid())
  userId     String
  title      String
  url        String
  notes      String?
  status     ResourceStatus @default(TO_READ)
  rating     Int?
  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
  @@index([categoryId])
}